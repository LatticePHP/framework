{
    "name": "lattice/starter-service",
    "description": "LatticePHP microservice starter application",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "starter",
        "microservice",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/starter-service"
    },
    "require": {
        "php": "^8.4",
        "lattice/core": "^1.0",
        "lattice/http": "^1.0",
        "lattice/routing": "^1.0",
        "lattice/microservices": "^1.0",
        "lattice/queue": "^1.0",
        "lattice/events": "^1.0",
        "lattice/database": "^1.0",
        "lattice/observability": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php bin/lattice serve"
    }
}
