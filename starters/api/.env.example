#==========================================================================
# APPLICATION
#==========================================================================
APP_NAME=LatticePHP
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=base64:YOUR_GENERATED_KEY_HERE
APP_TIMEZONE=UTC
APP_LOCALE=en

#==========================================================================
# SERVER
#==========================================================================
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

#==========================================================================
# DATABASE
#==========================================================================
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=

#==========================================================================
# AUTHENTICATION
#==========================================================================
AUTH_GUARD=jwt

# JWT (Symmetric - HS256)
JWT_SECRET=your-256-bit-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL=60
JWT_REFRESH_TTL=10080
JWT_ISSUER=http://localhost:8080

# JWT (Asymmetric - RS256, uncomment to use)
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY=/path/to/private.pem
# JWT_PUBLIC_KEY=/path/to/public.pem
# JWT_AUDIENCE=

# Password Hashing
HASH_DRIVER=bcrypt
BCRYPT_ROUNDS=12

# Super Admin
SUPER_ADMIN_ROLE=super-admin

#==========================================================================
# MULTI-TENANCY
#==========================================================================
TENANCY_MODE=single_db
TENANCY_RESOLVER=subdomain
TENANCY_BASE_DOMAIN=app.localhost
TENANCY_COLUMN=tenant_id
TENANCY_CACHE=true
TENANCY_CACHE_TTL=3600

# For db_per_tenant mode:
# TENANCY_MODE=db_per_tenant
# TENANCY_DB_PREFIX=tenant_

#==========================================================================
# WORKSPACES
#==========================================================================
WORKSPACE_ENABLED=true
WORKSPACE_RESOLVER=header
WORKSPACE_COLUMN=workspace_id
WORKSPACE_MAX_MEMBERS=50
WORKSPACE_MAX_PER_USER=10
WORKSPACE_INVITE_EXPIRES=7
WORKSPACE_MAX_PENDING_INVITES=20
WORKSPACE_DEFAULT_TIMEZONE=UTC
WORKSPACE_DEFAULT_CURRENCY=USD
WORKSPACE_DEFAULT_LOCALE=en

#==========================================================================
# CACHE
#==========================================================================
CACHE_STORE=file
CACHE_PREFIX=lattice_cache_
# CACHE_STORE=redis
# CACHE_REDIS_CONNECTION=cache
# CACHE_REDIS_LOCK_CONNECTION=default

#==========================================================================
# QUEUE
#==========================================================================
QUEUE_CONNECTION=sync
QUEUE_TABLE=jobs
QUEUE_NAME=default
QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database
# QUEUE_CONNECTION=redis
# QUEUE_REDIS_CONNECTION=default

#==========================================================================
# MAIL
#==========================================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_LOG_CHANNEL=default

#==========================================================================
# REDIS (when using redis for cache/queue/rate-limiting)
#==========================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

#==========================================================================
# FILESYSTEM
#==========================================================================
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

#==========================================================================
# CORS
#==========================================================================
CORS_ALLOWED_ORIGINS=*
CORS_MAX_AGE=86400
CORS_CREDENTIALS=false

#==========================================================================
# RATE LIMITING
#==========================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=60
RATE_LIMIT_DECAY=60
RATE_LIMIT_STORE=cache

#==========================================================================
# LOGGING
#==========================================================================
LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_LEVEL=debug
LOG_DAYS=14
LOG_STDERR_FORMATTER=json

#==========================================================================
# OBSERVABILITY
#==========================================================================
TRACING_ENABLED=false
TRACING_EXPORTER=otlp
TRACING_ENDPOINT=http://localhost:4318
TRACING_SERVICE_NAME=${APP_NAME}
TRACING_SAMPLE_RATE=1.0

METRICS_ENABLED=false
METRICS_PREFIX=lattice

AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=90

REQUEST_LOG_ENABLED=false
REQUEST_LOG_BODY=false

#==========================================================================
# WORKFLOW ENGINE
#==========================================================================
WORKFLOW_STORE=database
WORKFLOW_TABLE_EXECUTIONS=workflow_executions
WORKFLOW_TABLE_EVENTS=workflow_events
WORKFLOW_DEFAULT_QUEUE=workflows
WORKFLOW_ACTIVITY_QUEUE=activities

#==========================================================================
# ROADRUNNER (when using RoadRunner runtime)
#==========================================================================
# RR_HTTP_WORKERS=4
# RR_MAX_MEMORY=128
# RR_GRPC_WORKERS=2
# RR_GRPC_PORT=9001
