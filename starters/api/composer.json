{
    "name": "lattice/starter-api",
    "description": "LatticePHP API Starter",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "starter",
        "api",
        "rest",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/starter-api"
    },
    "require": {
        "php": "^8.4",
        "lattice/core": "^1.0",
        "lattice/http": "^1.0",
        "lattice/routing": "^1.0",
        "lattice/validation": "^1.0",
        "lattice/pipeline": "^1.0",
        "lattice/auth": "^1.0",
        "lattice/jwt": "^1.0",
        "lattice/database": "^1.0",
        "lattice/queue": "^1.0",
        "lattice/cache": "^1.0",
        "lattice/events": "^1.0",
        "lattice/mail": "^1.0",
        "lattice/notifications": "^1.0",
        "lattice/observability": "^1.0",
        "lattice/problem-details": "^1.0",
        "lattice/testing": "^1.0",
        "lattice/devtools": "^1.0",
        "lattice/filesystem": "^1.0",
        "lattice/scheduler": "^1.0",
        "lattice/serializer": "^1.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php bin/lattice serve"
    }
}
