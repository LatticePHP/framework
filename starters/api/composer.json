{
    "name": "lattice/starter-api",
    "description": "LatticePHP API Starter",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "lattice/core": "dev-main",
        "lattice/http": "dev-main",
        "lattice/routing": "dev-main",
        "lattice/validation": "dev-main",
        "lattice/pipeline": "dev-main",
        "lattice/auth": "dev-main",
        "lattice/jwt": "dev-main",
        "lattice/database": "dev-main",
        "lattice/queue": "dev-main",
        "lattice/cache": "dev-main",
        "lattice/events": "dev-main",
        "lattice/mail": "dev-main",
        "lattice/notifications": "dev-main",
        "lattice/observability": "dev-main",
        "lattice/problem-details": "dev-main",
        "lattice/testing": "dev-main",
        "lattice/devtools": "dev-main",
        "lattice/filesystem": "dev-main",
        "lattice/scheduler": "dev-main",
        "lattice/serializer": "dev-main",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php bin/lattice serve"
    }
}
