{
    "name": "lattice/starter-workflow",
    "description": "LatticePHP Workflow starter application",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "starter",
        "workflow",
        "durable-execution",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/starter-workflow"
    },
    "require": {
        "php": "^8.4",
        "lattice/core": "^1.0",
        "lattice/workflow": "^1.0",
        "lattice/workflow-store": "^1.0",
        "lattice/queue": "^1.0",
        "lattice/database": "^1.0",
        "lattice/scheduler": "^1.0",
        "lattice/observability": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php bin/lattice serve"
    }
}
