{
    "name": "lattice/http-client",
    "description": "HTTP client for outbound requests in LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "http-client",
        "guzzle",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/http-client"
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\HttpClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\HttpClient\\Tests\\": "tests/"
        }
    }
}
