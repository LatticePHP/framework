{
    "name": "lattice/graphql",
    "description": "Attribute-based GraphQL module for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "graphql",
        "attributes",
        "schema",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/graphql"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/core": "^1.0",
        "lattice/module": "^1.0",
        "lattice/http": "^1.0",
        "lattice/compiler": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\GraphQL\\Tests\\": "tests/"
        }
    }
}
