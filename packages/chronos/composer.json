{
    "name": "lattice/chronos",
    "description": "Workflow execution dashboard API for LatticePHP — monitor, signal, retry, and manage durable workflows",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "workflow",
        "dashboard",
        "chronos",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/chronos"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/workflow": "^1.0",
        "lattice/workflow-store": "^1.0",
        "lattice/http": "^1.0",
        "lattice/module": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Chronos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Chronos\\Tests\\": "tests/"
        }
    }
}
