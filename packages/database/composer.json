{
    "name": "lattice/database",
    "description": "Database integration for LatticePHP \u2014 wraps illuminate/database with Lattice module conventions",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "database",
        "eloquent",
        "orm",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/database"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Database\\Tests\\": "tests/"
        }
    }
}
