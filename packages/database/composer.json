{
    "name": "lattice/database",
    "description": "Database integration for LatticePHP — wraps illuminate/database with Lattice module conventions",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "ext-pdo_sqlite": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "autoload": {
        "psr-4": { "Lattice\\Database\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Lattice\\Database\\Tests\\": "tests/" }
    }
}
