{
    "name": "lattice/rate-limit",
    "description": "Rate limiting for LatticePHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "lattice/contracts": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "autoload": {
        "psr-4": {
            "Lattice\\RateLimit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\RateLimit\\Tests\\": "tests/"
        }
    }
}
