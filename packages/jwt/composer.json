{
    "name": "lattice/jwt",
    "description": "JWT token issuer and authentication guard for LatticePHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^0.1",
        "lattice/auth": "^0.1",
        "lcobucci/jwt": "^5.0",
        "lcobucci/clock": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Jwt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Jwt\\Tests\\": "tests/"
        }
    }
}
