{
    "name": "lattice/loom",
    "description": "Queue monitoring dashboard for LatticePHP — metrics collection, API, and real-time events",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "queue",
        "monitoring",
        "dashboard",
        "loom",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/loom"
    },
    "require": {
        "php": "^8.4",
        "lattice/queue": "^1.0",
        "lattice/events": "^1.0",
        "lattice/cache": "^1.0",
        "lattice/http": "^1.0",
        "lattice/module": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Loom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Loom\\Tests\\": "tests/"
        }
    }
}
