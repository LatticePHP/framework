{
    "name": "lattice/anvil",
    "description": "Server management and deployment CLI for LatticePHP — system detection, deployment pipeline, rollback",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "server",
        "deployment",
        "cli",
        "devops",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/anvil"
    },
    "require": {
        "php": "^8.4",
        "lattice/core": "^1.0",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/process": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Anvil\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Anvil\\Tests\\": "tests/"
        }
    }
}
