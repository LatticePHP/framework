{
    "name": "lattice/pipeline",
    "description": "Execution pipeline (guards, pipes, interceptors, filters) for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "pipeline",
        "middleware",
        "guards",
        "interceptors",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/pipeline"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Pipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Pipeline\\Tests\\": "tests/"
        }
    }
}
