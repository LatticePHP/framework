{
    "name": "lattice/pipeline",
    "description": "Execution pipeline (guards, pipes, interceptors, filters) for LatticePHP",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "require": {
        "php": "^8.4",
        "lattice/contracts": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Pipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Pipeline\\Tests\\": "tests/"
        }
    }
}
