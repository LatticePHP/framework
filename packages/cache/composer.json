{
    "name": "lattice/cache",
    "description": "Cache drivers and manager for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "cache",
        "caching",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/cache"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "illuminate/cache": "^12.0",
        "illuminate/contracts": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Cache\\Tests\\": "tests/"
        }
    }
}
