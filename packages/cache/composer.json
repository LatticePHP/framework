{
    "name": "lattice/cache",
    "description": "Cache drivers and manager for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "require": {
        "php": "^8.4",
        "lattice/contracts": "*",
        "illuminate/cache": "^12.0",
        "illuminate/contracts": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Cache\\Tests\\": "tests/"
        }
    }
}
