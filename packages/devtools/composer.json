{
    "name": "lattice/devtools",
    "description": "Code generators for scaffolding LatticePHP framework components",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/console": "^12.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\DevTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\DevTools\\Tests\\": "tests/"
        }
    }
}
