{
    "name": "lattice/devtools",
    "description": "Code generators for scaffolding LatticePHP framework components",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "devtools",
        "code-generation",
        "scaffolding",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/devtools"
    },
    "require": {
        "php": "^8.4",
        "illuminate/console": "^12.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\DevTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\DevTools\\Tests\\": "tests/"
        }
    }
}
