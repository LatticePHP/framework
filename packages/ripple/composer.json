{
    "name": "lattice/ripple",
    "description": "Native WebSocket server for real-time broadcasting in the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "websocket",
        "realtime",
        "broadcasting",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/ripple"
    },
    "require": {
        "php": "^8.4",
        "ext-sockets": "*",
        "lattice/contracts": "^1.0",
        "lattice/core": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Ripple\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Ripple\\Tests\\": "tests/"
        }
    }
}
