{
    "name": "lattice/authorization",
    "description": "Authorization policies and gates for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "authorization",
        "policies",
        "gates",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/authorization"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/auth": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Authorization\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Authorization\\Tests\\": "tests/"
        }
    }
}
