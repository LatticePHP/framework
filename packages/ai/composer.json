{
    "name": "lattice/ai",
    "description": "Multi-provider AI SDK for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "ai",
        "llm",
        "openai",
        "anthropic",
        "gemini",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/ai"
    },
    "require": {
        "php": "^8.4",
        "lattice/core": "^1.0",
        "lattice/http-client": "^1.0",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Ai\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Ai\\Tests\\": "tests/"
        }
    }
}
