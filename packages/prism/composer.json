{
    "name": "lattice/prism",
    "description": "Self-hosted error reporting: ingestion, fingerprinting, blob storage, and issue tracking for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "error-reporting",
        "error-tracking",
        "fingerprinting",
        "ndjson",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/prism"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/http": "^1.0",
        "lattice/database": "^1.0",
        "lattice/module": "^1.0",
        "lattice/cache": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Prism\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Prism\\Tests\\": "tests/"
        }
    }
}
