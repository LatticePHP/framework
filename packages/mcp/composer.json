{
    "name": "lattice/mcp",
    "description": "MCP (Model Context Protocol) server for LatticePHP — expose application services as tools, resources, and prompts for AI agents",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "mcp",
        "model-context-protocol",
        "ai",
        "tools",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/mcp"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/core": "^1.0",
        "lattice/module": "^1.0",
        "symfony/console": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Mcp\\Tests\\": "tests/"
        }
    }
}
