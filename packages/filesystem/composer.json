{
    "name": "lattice/filesystem",
    "description": "Filesystem abstraction layer for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "filesystem",
        "storage",
        "flysystem",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/filesystem"
    },
    "require": {
        "php": "^8.4",
        "illuminate/filesystem": "^12.0",
        "league/flysystem": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Filesystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Filesystem\\Tests\\": "tests/"
        }
    }
}
