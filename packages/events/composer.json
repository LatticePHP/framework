{
    "name": "lattice/events",
    "description": "Event dispatcher and subscriber system for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "events",
        "dispatcher",
        "event-driven",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/events"
    },
    "require": {
        "php": "^8.4",
        "illuminate/events": "^12.0",
        "illuminate/container": "^12.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Events\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Events\\Tests\\": "tests/"
        }
    }
}
