{
    "name": "lattice/openswoole",
    "description": "Experimental OpenSwoole integration for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "openswoole",
        "async",
        "coroutine",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/openswoole"
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\OpenSwoole\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\OpenSwoole\\Tests\\": "tests/"
        }
    }
}
