{
    "name": "lattice/compiler",
    "description": "Attribute discovery and module graph compilation for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "compiler",
        "attributes",
        "discovery",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/compiler"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Compiler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Compiler\\Tests\\": "tests/"
        }
    }
}
