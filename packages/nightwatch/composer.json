{
    "name": "lattice/nightwatch",
    "description": "Unified monitoring: debug inspector (dev) + metrics dashboard (prod) with file-system NDJSON storage for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "monitoring",
        "debug",
        "metrics",
        "ndjson",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/nightwatch"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/observability": "^1.0",
        "lattice/pipeline": "^1.0",
        "lattice/http": "^1.0",
        "lattice/module": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Nightwatch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Nightwatch\\Tests\\": "tests/"
        }
    }
}
