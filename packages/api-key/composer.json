{
    "name": "lattice/api-key",
    "description": "API key authentication for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "api-key",
        "authentication",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/api-key"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\ApiKey\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\ApiKey\\Tests\\": "tests/"
        }
    }
}
