{
    "name": "lattice/grpc",
    "description": "gRPC support for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "grpc",
        "rpc",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/grpc"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Grpc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Grpc\\Tests\\": "tests/"
        }
    }
}
