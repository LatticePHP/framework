{
    "name": "lattice/crm-example",
    "description": "CRM example application built entirely on LatticePHP framework",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "lattice/core": "*",
        "lattice/http": "*",
        "lattice/routing": "*",
        "lattice/module": "*",
        "lattice/compiler": "*",
        "lattice/pipeline": "*",
        "lattice/validation": "*",
        "lattice/database": "*",
        "lattice/auth": "*",
        "lattice/jwt": "*",
        "lattice/observability": "*",
        "lattice/problem-details": "*",
        "lattice/contracts": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Database\\Factories\\": "database/factories/",
            "App\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "migrate": "php bin/migrate.php",
        "seed": "php bin/seed.php",
        "serve": "php -S localhost:8080 -t public"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
